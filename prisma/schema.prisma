generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  role         String         @default("perito")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  varas        TribunalVara[]
  modelos      ModeloBase[]   @relation("ModelosBase")
}

model Parceiro {
  id          String   @id @default(cuid())
  nome        String
  tipo        String   @default("outro")
  email       String?
  telefone    String?
  cidade      String?
  estado      String?
  observacoes String?
  status      String   @default("ativo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModeloBase {
  id               String       @id @default(cuid())
  nome             String
  tipo             String
  descricao        String?
  area             String?
  nomeArquivo      String?
  caminhoArq       String?
  status           String       @default("ativo")
  totalUsos        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  especialidade    String?
  subEspecialidade String?
  uploadedById     String?
  versao           Int          @default(1)
  versaoPaiId      String?
  isActive         Boolean      @default(true)
  preferido        Boolean      @default(false)
  mimeType         String?
  tamanhoBytes     Int?
  textoExtraido    String?
  tokenCount       Int?
  processadoEm     DateTime?
  uploadedBy       User?        @relation("ModelosBase", fields: [uploadedById], references: [id])
  versaoPai        ModeloBase?  @relation("Versoes", fields: [versaoPaiId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  versoes          ModeloBase[] @relation("Versoes")
}

model DocumentoGerado {
  id         String   @id @default(cuid())
  tipo       String
  titulo     String
  periciaNum String?
  modeloId   String?
  status     String   @default("gerado")
  conteudo   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PeritoPerfil {
  id               String    @id @default(cuid())
  userId           String    @unique
  telefone         String?
  formacao         String?
  registro         String?
  especialidades   String    @default("[]")
  cursos           String    @default("[]")
  tribunais        String    @default("[]")
  estados          String    @default("[]")
  cidade           String?
  estado           String?
  areaAtuacao      String?
  areaPrincipal    String?
  areasSecundarias String    @default("[]")
  especialidades2  String    @default("[]")
  keywords         String    @default("[]")
  perfilCompleto   Boolean   @default(false)
  sincronizadoEm   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cpf              String?
  formacaoCustom   String?
}

model TribunalVara {
  id             String            @id @default(cuid())
  peritoId       String
  tribunalSigla  String
  tribunalNome   String
  varaNome       String
  varaId         String?
  cidade         String?
  uf             String?
  ativa          Boolean           @default(true)
  totalNomeacoes Int               @default(0)
  enderecoTexto  String?
  latitude       Float?
  longitude      Float?
  sincronizadoEm DateTime?
  criadoEm       DateTime          @default(now())
  user           User              @relation(fields: [peritoId], references: [id])
  nomeacoes      NomeacaoCitacao[]

  @@unique([peritoId, tribunalSigla, varaNome])
}

model VaraStats {
  id                    String   @id @default(cuid())
  tribunalSigla         String
  varaNome              String
  totalPeritosSugeridos Int      @default(0)
  totalNomeacoes        Int      @default(0)
  atualizadoEm          DateTime @updatedAt

  @@unique([tribunalSigla, varaNome])
}

model DemandaParceiro {
  id        String   @id @default(cuid())
  titulo    String
  descricao String?
  tipo      String
  cidade    String
  uf        String
  valor     Float
  prazo     String?
  status    String   @default("aberta")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proposta {
  id            String   @id @default(cuid())
  demandaId     String
  demandaTitulo String
  peritoId      String
  peritoNome    String
  status        String   @default("enviada")
  mensagem      String?
  valorProposto Float?
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PericiaEnderecoOverride {
  id        String   @id @default(cuid())
  pericoId  String
  userId    String
  endereco  String
  updatedAt DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PericiaStatusOverride {
  id        String   @id @default(cuid())
  pericoId  String
  userId    String
  status    String
  updatedAt DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PropostaHonorarios {
  id                 String   @id @default(cuid())
  pericoId           String
  pericoNumero       String
  pericoAssunto      String
  pericoProcesso     String
  pericoVara         String
  pericoPartes       String
  status             String   @default("rascunho")
  dataProposta       String   @default("")
  peritoNome         String   @default("")
  peritoQualificacao String   @default("")
  descricaoServicos  String   @default("")
  valorHonorarios    Float?
  prazoEstimado      String   @default("")
  observacoes        String   @default("")
  custoDeslocamento  Float?
  horasTecnicas      Float?
  complexidadeNota   String   @default("")
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PeritoEscritaProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tom                String   @default("formal")
  estruturaLaudo     String   @default("[]")
  estruturaProposta  String   @default("[]")
  templatesFavoritos String   @default("[]")
  expressoes         String   @default("[]")
  palavrasEvitar     String   @default("[]")
  abreviaturas       String   @default("[]")
  estiloConc         String   @default("")
  formulaFecho       String   @default("")
  notasIA            String   @default("")
  contextoRegional   String   @default("")
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}

model RadarConfig {
  id                   String    @id @default(cuid())
  peritoId             String    @unique
  tribunaisMonitorados String
  tribunaisResolvidos  String    @default("[]")
  tribunaisIgnorados   String    @default("[]")
  monitoramentoExtId   String?
  ultimaBusca          DateTime?
  totalCitacoes        Int       @default(0)
  saldoUltimaVerif     Float?
  lastMonitorSyncAt    DateTime?
  lastSearchSyncAt     DateTime?
  backfillCompletedAt  DateTime?
  criadoEm             DateTime  @default(now())
  atualizadoEm         DateTime  @updatedAt
}

model NomeacaoCitacao {
  id             String        @id @default(cuid())
  peritoId       String
  externalId     String
  diarioSigla    String
  diarioNome     String
  diarioData     DateTime
  snippet        String
  numeroProcesso String?
  linkCitacao    String
  visualizado    Boolean       @default(false)
  fonte          String        @default("escavador")
  tribunalVaraId String?
  // "pendente" | "aceita" | "rejeitada"
  status         String        @default("pendente")
  periciaId      String?
  criadoEm       DateTime      @default(now())
  tribunalVara   TribunalVara? @relation(fields: [tribunalVaraId], references: [id])

  @@unique([peritoId, externalId])
}

model Processo {
  id               String              @id @default(cuid())
  numeroProcesso   String              @unique
  tribunal         String
  classe           String?
  assunto          String?
  orgaoJulgador    String?
  dataDistribuicao String?
  dataUltimaAtu    String?
  partes           String              @default("[]")
  escavadorId      Int?
  criadoEm         DateTime            @default(now())
  atualizadoEm     DateTime            @updatedAt
  nomeacoes        Nomeacao[]
  documentos       ProcessoDocumento[]
}

model ProcessoDocumento {
  id               String    @id @default(cuid())
  processoId       String
  escavadorDocId   Int
  nome             String
  tipo             String?
  dataPublicacao   DateTime?
  urlPublica       String?
  paginas          Int?
  baixado          Boolean   @default(false)
  blobUrl          String?
  criadoEm         DateTime  @default(now())
  processo         Processo  @relation(fields: [processoId], references: [id])

  @@unique([processoId, escavadorDocId])
}

model Nomeacao {
  id             String   @id @default(cuid())
  peritoId       String
  processoId     String
  status         String   @default("novo")
  scoreMatch     Int      @default(0)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  extractedData  String?
  mimeType       String?
  nomeArquivo    String?
  periciaId      String?
  processSummary String?
  tamanhoBytes   Int?
  processo       Processo @relation(fields: [processoId], references: [id])

  @@unique([peritoId, processoId])
}

model Pericia {
  id              String       @id @default(cuid())
  peritoId        String
  numero          String
  assunto         String
  tipo            String
  processo        String?
  vara            String?
  partes          String?
  endereco        String?
  latitude        Float?
  longitude       Float?
  status          String       @default("planejada")
  prazo           String?
  valorHonorarios Float?
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt
  checkpoints     Checkpoint[] @relation("PericiaCheckpoints")
}

model RotaPericia {
  id           String   @id @default(cuid())
  peritoId     String
  titulo       String
  status       String   @default("em_andamento")
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  pericoId     String?
}

model Checkpoint {
  id            String    @id @default(cuid())
  rotaId        String
  ordem         Int
  titulo        String
  endereco      String?
  lat           Float?
  lng           Float?
  status        String    @default("pendente")
  chegadaEm     DateTime?
  criadoEm      DateTime  @default(now())
  pericoId      String?
  tribunalSigla String?
  varaNome      String?
  periciaId     String?
  pericia       Pericia?  @relation("PericiaCheckpoints", fields: [periciaId], references: [id])
}

model VaraContato {
  id                 String   @id @default(cuid())
  peritoId           String
  tribunalSigla      String
  varaNome           String
  telefone           String?
  email              String?
  juizNome           String?
  secretarioNome     String?
  secretarioLinkedin String?
  observacoes        String?
  updatedAt          DateTime @updatedAt
  criadoEm           DateTime @default(now())

  @@unique([peritoId, tribunalSigla, varaNome])
}

model CheckpointMidia {
  id           String   @id @default(cuid())
  checkpointId String
  tipo         String
  url          String?
  texto        String?
  descricao    String?
  criadoEm     DateTime @default(now())
}

model ProcessoIntake {
  id             String   @id @default(cuid())
  peritoId       String
  nomeArquivo    String
  tamanhoBytes   Int?
  mimeType       String?
  status         String   @default("upload_feito")
  dadosExtraidos String?
  resumo         String?
  periciaId      String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}
