generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  directUrl    = env("DIRECT_URL")
  relationMode = "prisma"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  passwordHash  String?        // nullable — social login users don't have a password
  role          String         @default("perito")
  emailVerified DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  varas         TribunalVara[]
  modelos       ModeloBase[]   @relation("ModelosBase")
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Parceiro {
  id          String   @id @default(cuid())
  nome        String
  tipo        String   @default("outro")
  email       String?
  telefone    String?
  cidade      String?
  estado      String?
  observacoes String?
  status      String   @default("ativo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModeloBase {
  id               String       @id @default(cuid())
  nome             String
  tipo             String
  descricao        String?
  area             String?
  nomeArquivo      String?
  caminhoArq       String?
  status           String       @default("ativo")
  totalUsos        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  especialidade    String?
  subEspecialidade String?
  uploadedById     String?
  versao           Int          @default(1)
  versaoPaiId      String?
  isActive         Boolean      @default(true)
  preferido        Boolean      @default(false)
  mimeType         String?
  tamanhoBytes     Int?
  textoExtraido    String?
  tokenCount       Int?
  processadoEm     DateTime?
  uploadedBy       User?        @relation("ModelosBase", fields: [uploadedById], references: [id])
  versaoPai        ModeloBase?  @relation("Versoes", fields: [versaoPaiId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  versoes          ModeloBase[] @relation("Versoes")
}

model DocumentoGerado {
  id         String   @id @default(cuid())
  tipo       String
  titulo     String
  periciaNum String?
  modeloId   String?
  status     String   @default("gerado")
  conteudo   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PeritoPerfil {
  id               String    @id @default(cuid())
  userId           String    @unique
  telefone         String?
  formacao         String?
  registro         String?
  especialidades   String    @default("[]")
  cursos           String    @default("[]")
  tribunais        String    @default("[]")
  estados          String    @default("[]")
  cidade           String?
  estado           String?
  areaAtuacao      String?
  areaPrincipal    String?
  areasSecundarias String    @default("[]")
  especialidades2  String    @default("[]")
  keywords         String    @default("[]")
  perfilCompleto   Boolean   @default(false)
  sincronizadoEm   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  cpf              String?
  formacaoCustom   String?
  // JSON map: { "TJRJ": { usuario: "...", senha: "..." }, ... }
  credenciaisTribunais String @default("{}")
}

model TribunalVara {
  id             String            @id @default(cuid())
  peritoId       String
  tribunalSigla  String
  tribunalNome   String
  varaNome       String
  varaId         String?
  cidade         String?
  uf             String?
  ativa          Boolean           @default(true)
  totalNomeacoes Int               @default(0)
  enderecoTexto  String?
  latitude       Float?
  longitude      Float?
  sincronizadoEm DateTime?
  criadoEm       DateTime          @default(now())
  user           User              @relation(fields: [peritoId], references: [id])
  nomeacoes      NomeacaoCitacao[]

  @@unique([peritoId, tribunalSigla, varaNome])
}

model VaraStats {
  id                    String   @id @default(cuid())
  tribunalSigla         String
  varaNome              String
  totalPeritosSugeridos Int      @default(0)
  totalNomeacoes        Int      @default(0)
  atualizadoEm          DateTime @updatedAt

  @@unique([tribunalSigla, varaNome])
}

model DemandaParceiro {
  id        String   @id @default(cuid())
  titulo    String
  descricao String?
  tipo      String
  cidade    String
  uf        String
  valor     Float
  prazo     String?
  status    String   @default("aberta")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proposta {
  id            String   @id @default(cuid())
  demandaId     String
  demandaTitulo String
  peritoId      String
  peritoNome    String
  status        String   @default("enviada")
  mensagem      String?
  valorProposto Float?
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PericiaEnderecoOverride {
  id        String   @id @default(cuid())
  pericoId  String
  userId    String
  endereco  String
  updatedAt DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PericiaStatusOverride {
  id        String   @id @default(cuid())
  pericoId  String
  userId    String
  status    String
  updatedAt DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PropostaHonorarios {
  id                 String   @id @default(cuid())
  pericoId           String
  pericoNumero       String
  pericoAssunto      String
  pericoProcesso     String
  pericoVara         String
  pericoPartes       String
  status             String   @default("rascunho")
  dataProposta       String   @default("")
  peritoNome         String   @default("")
  peritoQualificacao String   @default("")
  descricaoServicos  String   @default("")
  valorHonorarios    Float?
  prazoEstimado      String   @default("")
  observacoes        String   @default("")
  custoDeslocamento  Float?
  horasTecnicas      Float?
  complexidadeNota   String   @default("")
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([pericoId, userId])
}

model PeritoEscritaProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  tom                String   @default("formal")
  estruturaLaudo     String   @default("[]")
  estruturaProposta  String   @default("[]")
  templatesFavoritos String   @default("[]")
  expressoes         String   @default("[]")
  palavrasEvitar     String   @default("[]")
  abreviaturas       String   @default("[]")
  estiloConc         String   @default("")
  formulaFecho       String   @default("")
  notasIA            String   @default("")
  contextoRegional   String   @default("")
  criadoEm           DateTime @default(now())
  atualizadoEm       DateTime @updatedAt
}

model RadarConfig {
  id                   String    @id @default(cuid())
  peritoId             String    @unique
  tribunaisMonitorados String
  tribunaisResolvidos  String    @default("[]")
  tribunaisIgnorados   String    @default("[]")
  monitoramentoExtId   String?
  ultimaBusca          DateTime?
  totalCitacoes        Int       @default(0)
  saldoUltimaVerif     Float?
  lastMonitorSyncAt    DateTime?
  lastSearchSyncAt     DateTime?
  backfillCompletedAt  DateTime?
  criadoEm             DateTime  @default(now())
  atualizadoEm         DateTime  @updatedAt
}

model NomeacaoCitacao {
  id             String        @id @default(cuid())
  peritoId       String
  externalId     String
  diarioSigla    String
  diarioNome     String
  diarioData     DateTime
  snippet        String
  numeroProcesso String?
  linkCitacao    String
  visualizado    Boolean       @default(false)
  fonte          String        @default("escavador")
  tribunalVaraId String?
  // "pendente" | "aceita" | "rejeitada"
  status         String        @default("pendente")
  periciaId      String?
  criadoEm       DateTime      @default(now())
  tribunalVara   TribunalVara? @relation(fields: [tribunalVaraId], references: [id])

  @@unique([peritoId, externalId])
}

model Processo {
  id               String              @id @default(cuid())
  numeroProcesso   String              @unique
  tribunal         String
  classe           String?
  assunto          String?
  orgaoJulgador    String?
  dataDistribuicao String?
  dataUltimaAtu    String?
  partes           String              @default("[]")
  escavadorId      Int?
  criadoEm         DateTime            @default(now())
  atualizadoEm     DateTime            @updatedAt
  nomeacoes        Nomeacao[]
  documentos       ProcessoDocumento[]
}

model ProcessoDocumento {
  id               String    @id @default(cuid())
  processoId       String
  escavadorDocId   Int?      // v1 numeric ID (nullable — v2 uses chaveV2)
  chaveV2          String?   // v2 string key from Escavador API
  nome             String
  tipo             String?
  dataPublicacao   DateTime?
  urlPublica       String?
  paginas          Int?
  baixado          Boolean   @default(false)
  blobUrl          String?
  criadoEm         DateTime  @default(now())
  processo         Processo  @relation(fields: [processoId], references: [id])

  @@unique([processoId, escavadorDocId])
  @@unique([processoId, chaveV2])
}

model Nomeacao {
  id             String   @id @default(cuid())
  peritoId       String
  processoId     String
  status         String   @default("novo")
  scoreMatch     Int      @default(0)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
  extractedData  String?
  mimeType       String?
  nomeArquivo    String?
  periciaId      String?
  processSummary String?
  tamanhoBytes   Int?
  processo       Processo @relation(fields: [processoId], references: [id])

  @@unique([peritoId, processoId])
}

model Pericia {
  id              String       @id @default(cuid())
  peritoId        String
  numero          String
  assunto         String
  tipo            String
  tags            String    @default("[]") // JSON: string[] — ex: ["Água","Energia","Avaliação Imobiliária"]
  processo        String?
  vara            String?
  partes          String?
  endereco        String?
  latitude        Float?
  longitude       Float?
  status          String       @default("planejada")
  prazo           String?
  valorHonorarios Float?
  criadoEm        DateTime     @default(now())
  atualizadoEm    DateTime     @updatedAt
  checkpoints     Checkpoint[] @relation("PericiaCheckpoints")
}

model RotaPericia {
  id           String   @id @default(cuid())
  peritoId     String
  titulo       String
  status       String   @default("em_andamento")
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  pericoId     String?
}

model Checkpoint {
  id              String    @id @default(cuid())
  rotaId          String
  ordem           Int
  titulo          String
  endereco        String?
  lat             Float?
  lng             Float?
  status          String    @default("pendente")
  chegadaEm       DateTime?
  criadoEm        DateTime  @default(now())
  pericoId        String?
  tribunalSigla   String?
  varaNome        String?
  comarca         String?
  periciaId       String?
  pericia         Pericia?  @relation("PericiaCheckpoints", fields: [periciaId], references: [id])
  // Dados coletados na visita
  juizNome        String?
  secretarioNome  String?
  foiNomeado      Boolean   @default(false)
  observacoes     String?
  varasJson       String?   // JSON: varas dentro desta comarca [{varaNome, juiz, secretario, foiNomeado, visitada}]
}

model VaraContato {
  id                 String   @id @default(cuid())
  peritoId           String
  tribunalSigla      String
  varaNome           String
  telefone           String?
  email              String?
  juizNome           String?
  secretarioNome     String?
  secretarioLinkedin String?
  observacoes        String?
  updatedAt          DateTime @updatedAt
  criadoEm           DateTime @default(now())

  @@unique([peritoId, tribunalSigla, varaNome])
}

// ─── Varas públicas (registro oficial TJRJ) ──────────────────────────────────

model VaraPublica {
  id             String             @id @default(cuid())
  uf             String             @default("RJ")
  tribunal       String             @default("TJRJ")
  comarca        String
  varaNome       String
  emailPrincipal String?
  emailGabinete  String?
  telefone       String?
  fax            String?
  endereco       String?
  cep            String?
  juizTitular    String?
  ativa          Boolean            @default(true)
  criadoEm       DateTime           @default(now())
  atualizadoEm   DateTime           @updatedAt
  visitas        ProspeccaoVisita[]

  @@unique([uf, comarca, varaNome])
  @@index([uf, comarca])
}

// ─── Visitas de prospecção por perito ────────────────────────────────────────

model ProspeccaoVisita {
  id           String       @id @default(cuid())
  peritoId     String
  varaId       String?
  comarca      String
  varaNome     String
  tribunal     String       @default("TJRJ")
  uf           String       @default("RJ")
  dataVisita   DateTime
  resultado      String       @default("realizada") // realizada | nao_atendido | remarcado | cancelado
  anotacoes      String?
  juizEncontrado String?
  contatoNome    String?
  contatoRole    String?
  contatoEmail   String?      // e-mail fornecido pelo contato
  contatoFotoUrl String?      // URL da foto do secretário/contato
  emailEnviadoEm DateTime?    // última vez que enviou e-mail para esta vara
  followUpEm     DateTime?
  criadoEm       DateTime     @default(now())
  atualizadoEm   DateTime     @updatedAt
  vara           VaraPublica? @relation(fields: [varaId], references: [id])

  @@index([peritoId])
  @@index([varaId])
}

model CheckpointMidia {
  id           String   @id @default(cuid())
  checkpointId String
  tipo         String
  url          String?
  texto        String?
  descricao    String?
  criadoEm     DateTime @default(now())
}

model ProcessoIntake {
  id             String   @id @default(cuid())
  peritoId       String
  nomeArquivo    String
  tamanhoBytes   Int?
  mimeType       String?
  status         String   @default("upload_feito")
  dadosExtraidos String?
  resumo         String?
  periciaId      String?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}

// ─── Proposta de Honorários ───────────────────────────────────────────────────

model ProposalTemplate {
  id           String    @id @default(cuid())
  userId       String
  nome         String
  descricao    String?
  blobUrl      String
  nomeArquivo  String
  tamanhoBytes Int
  tagsDetected String    @default("[]")  // JSON: string[]
  ativo        Boolean   @default(true)
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  proposals    FeeProposal[]

  @@index([userId])
}

model FeeProposal {
  id                 String    @id @default(cuid())
  periciaId          String
  userId             String

  // Snapshot do processo no momento da geração
  numeroProcesso     String    @default("")
  tribunal           String    @default("")
  vara               String    @default("")
  assunto            String    @default("")
  partes             String    @default("")
  tipoPericia        String    @default("")
  endereco           String    @default("")
  quesitos           String    @default("[]")   // JSON: string[]

  // Dados do perito
  peritoNome         String    @default("")
  peritoQualificacao String    @default("")

  // Conteúdo gerado (editável)
  descricaoServicos  String    @default("")
  resumoTecnico      String    @default("")
  metodologia        String    @default("")
  fasesEstimadas     String    @default("[]")   // JSON: string[]
  horasEstimadas     Float?
  despesasPrevistas  String    @default("")
  valorHonorarios    Float?
  custoDeslocamento  Float?
  prazoEntrega       String    @default("")
  condicoesPagamento String    @default("")
  observacoes        String    @default("")
  riscosEPendencias  String    @default("[]")   // JSON: string[]
  complexidade       String    @default("")

  // Controle de geração
  templateId         String?
  template           ProposalTemplate? @relation(fields: [templateId], references: [id])
  iaModel            String    @default("")
  iaRawOutput        String    @default("")     // JSON bruto — auditoria
  status             String    @default("rascunho") // rascunho | gerada | enviada
  versaoAtual        Int       @default(1)
  dataProposta       String    @default("")

  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt
  versoes            FeeProposalVersion[]

  @@unique([periciaId, userId])
  @@index([userId])
}

model FeeProposalVersion {
  id         String   @id @default(cuid())
  proposalId String
  versao     Int
  snapshot   String   // JSON completo dos campos da proposta naquele momento
  iaModel    String   @default("")
  criadoEm   DateTime @default(now())

  proposal   FeeProposal @relation(fields: [proposalId], references: [id])

  @@index([proposalId])
}

// ─── Agenda do Perito ─────────────────────────────────────────────────────────

model AgendaItem {
  id          String    @id @default(cuid())
  periciaId   String
  peritoId    String
  titulo      String
  descricao   String?
  tipo        String    @default("action")   // deadline | action | reminder
  origem      String    @default("user")     // ai | user | system
  dataLimite  DateTime?
  status      String    @default("pending")  // pending | completed
  prioridade  String    @default("normal")   // alta | normal | baixa
  confianca   Float?    // AI confidence score (0-1)
  sourceKey   String?   // dedup key para evitar duplicatas de AI/system
  criadoEm    DateTime  @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([periciaId, sourceKey])
  @@index([peritoId])
  @@index([periciaId])
}

// ─── Laudo Pericial ───────────────────────────────────────────────────────────

model LaudoTemplate {
  id           String   @id @default(cuid())
  userId       String?  // null = template padrão PeriLaB
  categoria    String   // Água | Energia | Médica | Grafotécnica | custom
  nome         String
  secoes       String   // JSON: { titulo: string, placeholder: string }[]
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([userId])
  @@index([categoria])
}

model LaudoDraft {
  id          String   @id @default(cuid())
  periciaId   String
  userId      String
  templateId  String?
  categoria   String   @default("")
  secoes      String   @default("[]") // JSON: { titulo: string, conteudo: string }[]
  status      String   @default("rascunho") // rascunho | revisado | finalizado
  iaModel     String   @default("")
  iaRawOutput String   @default("")
  versao      Int      @default(1)
  criadoEm    DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([periciaId, userId])
  @@index([userId])
}

// ─── Judit — Movimentacoes do processo ───────────────────────────────────────
// Isolado do Escavador. Source sempre = 'judit'.

model ProcessMovement {
  id          String   @id @default(cuid())
  periciaId   String
  source      String   @default("judit") // provedor de origem
  externalId  String?  // ID da movimentacao na Judit
  eventDate   DateTime
  capturedAt  DateTime @default(now())
  type        String?  // tipo da movimentacao (ex: "despacho", "sentenca")
  description String
  content     String?  // conteudo complementar
  rawJson     String?  // payload bruto JSON para auditoria

  @@unique([periciaId, source, externalId])
  @@index([periciaId])
}

// ─── Judit — Anexos/Documentos do processo ───────────────────────────────────
// Separado do ProcessoDocumento (Escavador). Nao conflita.

model ProcessAttachment {
  id                String   @id @default(cuid())
  periciaId         String
  source            String   @default("judit")
  externalId        String   // ID do anexo na Judit
  name              String
  type              String?  // tipo do documento
  mimeType          String?
  isPublic          Boolean  @default(false)
  downloadAvailable Boolean  @default(false)
  url               String?  // URL original do provedor (Judit)
  blobUrl           String?  // URL no Vercel Blob apos download
  blobPathname      String?  // pathname no Vercel Blob (para del)
  sizeBytes         Int?
  downloadStatus    String   @default("pending") // pending | downloaded | failed | unavailable
  downloadError     String?  // mensagem de erro se falhou
  downloadedAt      DateTime?
  publishedAt       DateTime?
  capturedAt        DateTime @default(now())

  @@unique([periciaId, source, externalId])
  @@index([periciaId])
}

